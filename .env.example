# ============================================================
#  MQCI 2.0 — Configuration d'environnement
#  Copier ce fichier en .env et remplir les valeurs réelles
#  NE JAMAIS versionner le fichier .env dans Git
# ============================================================

# --- Base de données ---
DB_HOST=localhost
DB_NAME=mqci
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Application ---
APP_NAME=MAQCI
APP_VERSION=2.0
APP_ENV=local
# local | production
APP_BASE_URL=http://localhost/maqci/public/
APP_PUBLIC_PATH=/maqci/public/

# --- Chemins système ---
MYSQLDUMP_PATH=C:/wamp64/bin/mysql/mysql8.0.31/bin

# --- Licence ---
LICENCE_SECRET=change_moi_avec_une_vraie_valeur_secrete_longue
